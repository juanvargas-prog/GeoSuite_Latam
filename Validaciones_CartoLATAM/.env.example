# .env.example — Copia este archivo como .env y completa los valores
# ¡NUNCA subas .env a GitHub — está en .gitignore!
# ─────────────────────────────────────────────────────────────────────────────

# ── ACTUALIZACIÓN AUTOMÁTICA DESDE GITHUB ────────────────────────────────────
# Solicita el token al administrador del repositorio.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=bryanmora-star/validaciones_cartolatam

# ── CREDENCIALES DE GOOGLE (sistema cifrado) ──────────────────────────────────
# El archivo JSON de la cuenta de servicios está cifrado en el repositorio.
# Solo necesitas esta clave — solicítala al administrador por canal seguro.
CREDENTIALS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# ── CORREO ────────────────────────────────────────────────────────────────────
# Tu correo y contraseña de aplicación de Google.
# Obtén la contraseña en: Cuenta Google → Seguridad → Contraseñas de aplicaciones
GMAIL_REMITENTE=tucorreo@empresa.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Destinatarios por defecto (editables también desde la interfaz del plugin)
CORREO_REPORTE_COMPLETO=lider@empresa.com
CORREO_REPORTE_RESUMIDO=equipo@empresa.com
